{
  "name": "simpleshare-monorepo",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=simpleshare-web",
    "build:server": "turbo run build --filter=simpleshare-signalling-server",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=simpleshare-web",
    "dev:server": "turbo run dev --filter=simpleshare-signalling-server",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
